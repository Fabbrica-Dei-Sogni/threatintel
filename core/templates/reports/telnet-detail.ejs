<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="UTF-8">
    <style>
        body { font-family: 'Courier New', monospace; color: #333; margin: 40px; }
        .header { border-bottom: 2px solid #34495e; padding-bottom: 10px; font-family: sans-serif; }
        .title { color: #2c3e50; text-transform: uppercase; font-size: 18px; font-weight: bold; }
        .terminal-box { background: #2c3e50; color: #ecf0f1; padding: 15px; border-radius: 5px; margin-top: 20px; font-size: 12px; }
        .section-title { font-family: sans-serif; background: #34495e; color: #fff; padding: 5px 10px; margin-top: 25px; font-size: 14px; }
        .timeline-entry { border-left: 2px solid #bdc3c7; padding-left: 15px; margin-bottom: 10px; font-size: 12px; }
        .timestamp { color: #7f8c8d; font-size: 10px; }
        .cmd { color: #2ecc71; font-weight: bold; }
        .auth { color: #e67e22; }
        .footer { margin-top: 40px; font-size: 10px; color: #bdc3c7; text-align: center; font-family: sans-serif; }
    </style>
</head>
<body>
    <div class="header">
        <div class="title"><%= data.title %></div>
        <div style="font-size: 12px;">Session ID: <%= data.sessionId %></div>
    </div>

    <div style="font-family: sans-serif; font-size: 12px; margin-top: 15px;">
        <strong>Soggetto:</strong> <%= data.ip %> (<%= data.ipInfo.country %>)<br>
        <strong>Protocollo:</strong> <%= data.sessionInfo.protocol.toUpperCase() %><br>
        <strong>Data Inizio:</strong> <%= new Date(data.sessionInfo.startTime).toLocaleString() %>
    </div>

    <div class="section-title">Timeline delle Operazioni Hostili</div>
    <div style="margin-top: 15px;">
        <% data.timeline.forEach(function(e) { %>
            <div class="timeline-entry">
                <span class="timestamp">[<%= new Date(e.timestamp).toLocaleTimeString() %>]</span>
                <% if (e.type.includes('login')) { %>
                    <span class="auth">TENTATIVO LOGIN: <%= e.username %> / <%= e.password %></span>
                <% } else if (e.input) { %>
                    <span class="cmd">COMANDO: <%= e.input %></span>
                <% } else if (e.message) { %>
                    <span><%= e.message %></span>
                <% } else { %>
                    <span style="color: #95a5a6;"><%= e.type %></span>
                <% } %>
            </div>
        <% }); %>
    </div>

    <div class="footer">ThreatIntel Honeypot System - Forensic Session Report</div>
</body>
</html>
