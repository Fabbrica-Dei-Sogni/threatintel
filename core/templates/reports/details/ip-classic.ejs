<!DOCTYPE html>
<html lang="<%= locale.split('-')[0] %>">

<head>
    <meta charset="UTF-8">
    <title><%= t('reports.common.agencyName') %> - <%= t('reports.common.forensicReport') %> - <%= data.ip %>
    </title>
    <style>
        :root {
            --bg-paper: #ffffff;
            --text-main: #1a202c;
            --text-muted: #4a5568;
            --primary: #2c5282;
            --danger: #c53030;
            --warning: #b7791f;
            --success: #2f855a;
            --border: #e2e8f0;
            --section-bg: #f7fafc;
        }

        @page {
            margin: 15mm;
            size: A4;
        }

        body {
            font-family: 'Helvetica', 'Arial', sans-serif;
            background-color: var(--bg-paper);
            color: var(--text-main);
            margin: 0;
            padding: 0;
            line-height: 1.4;
        }

        .document-container {
            max-width: 100%;
        }

        .header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            border-bottom: 2px solid var(--text-main);
            padding-bottom: 15px;
            margin-bottom: 25px;
        }

        .header-left {
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .logo-box {
            width: 50px;
            height: 50px;
            border: 1px solid var(--border);
            padding: 2px;
            background: #fff;
        }

        .logo-img {
            width: 100%;
            height: 100%;
            object-fit: contain;
        }

        .title-group h1 {
            margin: 0;
            font-size: 22px;
            text-transform: uppercase;
            letter-spacing: 1px;
            font-weight: 900;
        }

        .title-group p {
            margin: 2px 0 0;
            font-size: 10px;
            text-transform: uppercase;
            font-weight: 700;
            color: var(--text-muted);
        }

        .header-right {
            text-align: right;
        }

        .dossier-id {
            font-size: 11px;
            color: var(--text-muted);
            font-family: monospace;
        }

        .meta-strip {
            display: flex;
            justify-content: space-between;
            background: var(--section-bg);
            padding: 10px 15px;
            border: 1px solid var(--border);
            font-size: 11px;
            margin-bottom: 25px;
        }

        .section {
            margin-bottom: 25px;
        }

        .section-header {
            border-bottom: 1px solid var(--text-main);
            margin-bottom: 12px;
            padding-bottom: 4px;
        }

        .section-title {
            font-size: 14px;
            font-weight: 800;
            text-transform: uppercase;
            color: var(--primary);
        }

        .summary-block {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 1px;
            background: var(--border);
            border: 1px solid var(--border);
            margin-bottom: 25px;
        }

        .summary-item {
            background: #fff;
            padding: 15px;
            text-align: center;
        }

        .summary-label {
            font-size: 10px;
            text-transform: uppercase;
            color: var(--text-muted);
            font-weight: 700;
            display: block;
            margin-bottom: 5px;
        }

        .summary-value {
            font-size: 18px;
            font-weight: 800;
        }

        .panel-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
        }

        .detail-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 12px;
        }

        .detail-table th {
            text-align: left;
            padding: 6px 0;
            color: var(--text-muted);
            width: 45%;
            font-weight: 600;
        }

        .detail-table td {
            text-align: right;
            padding: 6px 0;
            font-weight: 700;
        }

        .report-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 10px;
            margin-top: 10px;
        }

        .report-table th {
            background: var(--section-bg);
            padding: 8px;
            text-align: left;
            border: 1px solid var(--border);
            text-transform: uppercase;
        }

        .report-table td {
            padding: 8px;
            border: 1px solid var(--border);
        }

        .badge-list {
            display: flex;
            flex-wrap: wrap;
            gap: 4px;
            margin-top: 4px;
        }

        .badge {
            font-size: 8px;
            padding: 1px 4px;
            border-radius: 2px;
            font-weight: 700;
            border: 1px solid var(--border);
            background: var(--section-bg);
        }

        .badge-danger {
            color: var(--danger);
            border-color: var(--danger);
            background: #fff5f5;
        }

        .badge-warning {
            color: var(--warning);
            border-color: var(--warning);
            background: #fffaf0;
        }

        .badge-primary {
            color: var(--primary);
            border-color: var(--primary);
            background: #ebf8ff;
        }

        .whois-box {
            background: #1a202c;
            color: #a0aec0;
            padding: 15px;
            font-family: 'Courier New', Courier, monospace;
            font-size: 8.5px;
            white-space: pre-wrap;
            word-break: break-all;
            border-radius: 4px;
            border: 1px solid var(--border);
            line-height: 1.25;
            margin-top: 10px;
        }

        .footer {
            margin-top: 50px;
            border-top: 1px solid var(--border);
            padding-top: 10px;
            text-align: center;
            font-size: 9px;
            color: var(--text-muted);
            font-style: italic;
        }

        .page-counter {
            text-align: right;
            font-size: 9px;
            margin-top: 5px;
        }
    </style>
</head>

<body>
    <div class="document-container">
        <header class="header">
            <div class="header-left">
                <div class="logo-box">
                    <% if (typeof logoBase64 !=='undefined' && logoBase64) { %>
                        <img src="<%= logoBase64 %>" class="logo-img" alt="Seal">
                        <% } else { %>
                            <div style="font-size: 24px; font-weight: bold; color: #cbd5e0;">TI</div>
                            <% } %>
                </div>
                <div class="title-group">
                    <h1><%= t('reports.common.agencyName') %></h1>
                    <p><%= t('reports.ipDetail.division') %> • <%= t('reports.common.forensicReport') %></p>
                </div>
            </div>
            <div class="header-right">
                <div class="dossier-id">REF: IP-<%= data.ip.replace(/\./g, '' ) %>-<%= Date.now().toString().slice(-6)
                            %>
                </div>
            </div>
        </header>

        <div class="meta-strip">
            <span><strong><%= t('reports.common.investigatedIp') %>:</strong>
                <%= data.ip %>
            </span>
            <span><strong><%= t('reports.common.generatedAt') %>:</strong>
                <%= data.generatedAt %>
            </span>
            <span><strong><%= t('reports.ipDetail.class') %>:</strong> <%= t('reports.ipDetail.classValue') %></span>
        </div>

        <div class="section">
            <div class="section-header">
                <div class="section-title"><%= t('reports.ipDetail.summaryTitle') %></div>
            </div>
            <div class="summary-block">
                <div class="summary-item">
                    <span class="summary-label"><%= t('reports.attackDetail.abuseConfidence') %></span>
                    <span class="summary-value"
                        style="color: <%= data.abuse.confidenceScore > 50 ? 'var(--danger)' : (data.abuse.confidenceScore > 20 ? 'var(--warning)' : 'var(--success)') %>">
                        <%= data.abuse.confidenceScore %>%
                    </span>
                </div>
                <div class="summary-item">
                    <span class="summary-label"><%= t('reports.attackDetail.totalReports') %></span>
                    <span class="summary-value">
                        <%= data.abuse.totalReports %>
                    </span>
                </div>
                <div class="summary-item">
                    <span class="summary-label"><%= t('reports.attackDetail.lastReported') %></span>
                    <span class="summary-value" style="font-size: 11px;">
                        <%= data.abuse.lastReportedAt %>
                    </span>
                </div>
                <div class="summary-item">
                    <span class="summary-label"><%= t('reports.ipDetail.whitelistStatus') %></span>
                    <span class="summary-value"
                        style="color: <%= data.abuse.isWhitelisted ? 'var(--success)' : 'var(--text-muted)' %>">
                        <%= data.abuse.isWhitelisted ? t('reports.ipDetail.safe') : t('reports.ipDetail.notListed') %>
                    </span>
                </div>
            </div>
        </div>

        <div class="panel-grid">
            <div class="section">
                <div class="section-header">
                    <div class="section-title"><%= t('reports.ipDetail.networkContext') %></div>
                </div>
                <table class="detail-table" style="margin-bottom: 10px;">
                    <tr>
                        <th><%= t('reports.attackDetail.ispOrg') %></th>
                        <td>
                            <%= data.abuse.isp %>
                        </td>
                    </tr>
                    <tr>
                        <th><%= t('reports.attackDetail.domain') %></th>
                        <td style="font-family: monospace;">
                            <%= data.abuse.domain %>
                        </td>
                    </tr>
                    <tr>
                        <th><%= t('reports.ipDetail.usageType') %></th>
                        <td>
                            <%= data.abuse.usageType %>
                        </td>
                    </tr>
                    <tr>
                        <th><%= t('reports.attackDetail.country') %></th>
                        <td>
                            <%= data.details.country %> (<%= data.abuse.countryCode %>)
                        </td>
                    </tr>
                </table>
                <div class="badge-list">
                    <% if (data.abuse.isTor) { %>
                        <span class="badge badge-danger"><%= t('reports.ipDetail.markers.tor') %></span>
                        <% } %>
                            <% if (data.abuse.confidenceScore> 80) { %>
                                <span class="badge badge-danger"><%= t('reports.ipDetail.markers.highRisk') %></span>
                                <% } else if (data.abuse.confidenceScore> 30) { %>
                                    <span class="badge badge-warning"><%= t('reports.ipDetail.markers.suspicious') %></span>
                                    <% } %>
                                        <% if (data.abuse.isWhitelisted) { %>
                                            <span class="badge badge-primary"><%= t('reports.ipDetail.markers.whitelisted') %></span>
                                            <% } %>
                </div>
            </div>

            <div class="section">
                <div class="section-header">
                    <div class="section-title"><%= t('reports.ipDetail.geolocation') %></div>
                </div>
                <table class="detail-table">
                    <tr>
                        <th><%= t('reports.attackDetail.country') %> (ISO)</th>
                        <td>
                            <%= data.details.country %>
                        </td>
                    </tr>
                    <tr>
                        <th><%= t('reports.attackDetail.city') %> / Area</th>
                        <td>
                            <%= data.details.city %>
                        </td>
                    </tr>
                    <tr>
                        <th><%= t('reports.attackDetail.coordinates') %></th>
                        <td>
                            <%= data.details.coordinates %>
                        </td>
                    </tr>
                </table>
                <div style="margin-top: 15px; font-size: 10px; color: var(--text-muted); font-style: italic;">
                    <%= t('reports.ipDetail.geoNote') %>
                </div>
            </div>
        </div>

        <div class="section">
            <div class="section-header">
                <div class="section-title"><%= t('reports.ipDetail.reportsTimeline') %></div>
            </div>
            <% if (data.abuseReports && data.abuseReports.length> 0) { %>
                <table class="report-table">
                    <thead>
                        <tr>
                            <th width="15%"><%= t('reports.ipDetail.reportTable.date') %></th>
                            <th width="25%"><%= t('reports.ipDetail.reportTable.categories') %></th>
                            <th><%= t('reports.ipDetail.reportTable.comment') %></th>
                        </tr>
                    </thead>
                    <tbody>
                        <% data.abuseReports.slice(0, 15).forEach(function(r) { %>
                            <tr>
                                <td style="font-weight: bold;">
                                    <%= new Date(r.date).toLocaleDateString(locale) %>
                                </td>
                                <td>
                                    <div class="badge-list">
                                        <% (r.categories || []).forEach(function(cat) { %>
                                            <span class="badge">
                                                <%= cat.name %>
                                            </span>
                                            <% }); %>
                                    </div>
                                </td>
                                <td style="font-style: italic; color: var(--text-muted); font-size: 9px;">
                                    <%= r.comment %>
                                </td>
                            </tr>
                            <% }); %>
                    </tbody>
                </table>
                <% if (data.abuseReports.length> 15) { %>
                    <div style="font-size: 9px; color: var(--text-muted); margin-top: 5px; text-align: right;">
                        <%= t('reports.ipDetail.truncated', { count: 15, total: data.abuseReports.length }) %>
                    </div>
                    <% } %>
                        <% } else { %>
                            <div
                                style="background: var(--section-bg); padding: 15px; border: 1px solid var(--border); text-align: center; color: var(--text-muted); font-size: 12px;">
                                <%= t('reports.ipDetail.noAbuse') %>
                            </div>
                            <% } %>
        </div>

        <div class="section">
            <div class="section-header">
                <div class="section-title"><%= t('reports.ipDetail.whoisTitle') %></div>
            </div>
            <div class="whois-box">
                <%= data.whois %>
            </div>
        </div>

        <footer class="footer">
            <%= t('reports.common.proprietary') %>
        </footer>
        <div class="page-counter"><%= t('reports.common.page') %> 1 <%= t('reports.common.of') %> 1</div>
    </div>
</body>

</html>
</html>