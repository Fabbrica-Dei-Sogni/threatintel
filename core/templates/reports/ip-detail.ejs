<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="UTF-8">
    <style>
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; color: #333; margin: 40px; }
        .header { border-bottom: 3px solid #c0392b; padding-bottom: 10px; }
        .title { color: #c0392b; text-transform: uppercase; font-size: 22px; font-weight: bold; }
        .score-box { float: right; background: #c0392b; color: white; padding: 15px; border-radius: 5px; text-align: center; }
        .score-value { font-size: 24px; font-weight: bold; }
        .section-title { border-bottom: 1px solid #eee; color: #2c3e50; padding: 5px 0; margin-top: 30px; font-size: 16px; font-weight: bold; text-transform: uppercase; }
        .info-table { width: 100%; margin-top: 15px; }
        .info-table td { padding: 8px 0; border-bottom: 1px solid #f9f9f9; font-size: 13px; }
        .label { font-weight: bold; width: 30%; color: #7f8c8d; }
        .whois-raw { background: #f4f4f4; padding: 15px; font-family: monospace; font-size: 10px; white-space: pre-wrap; margin-top: 10px; border: 1px solid #ddd; }
        .report-item { margin-bottom: 15px; padding: 10px; border-left: 3px solid #c0392b; background: #fff5f5; font-size: 12px; }
        .footer { margin-top: 50px; font-size: 10px; color: #bdc3c7; text-align: center; }
    </style>
</head>
<body>
    <div class="score-box">
        ABUSE SCORE<br>
        <span class="score-value"><%= data.details.abuseScore %>%</span>
    </div>
    
    <div class="header">
        <div class="title"><%= data.title %></div>
        <div style="font-size: 14px;">Target IP: <%= data.ip %></div>
    </div>

    <div class="section-title">Network Context & Geolocation</div>
    <table class="info-table">
        <tr><td class="label">Paese:</td><td><%= data.details.country %> (<%= data.details.countryCode %>)</td></tr>
        <tr><td class="label">Città:</td><td><%= data.details.city %></td></tr>
        <tr><td class="label">ISP / Org:</td><td><%= data.details.isp %></td></tr>
        <tr><td class="label">Usage Type:</td><td><%= data.details.usageType %></td></tr>
        <tr><td class="label">Tor Node:</td><td><%= data.details.isTor ? 'SÌ (Rischio Elevato)' : 'NO' %></td></tr>
    </table>

    <div class="section-title">AbuseIPDB Incident Reports</div>
    <div style="margin-top: 10px;">
        <% if (data.abuseReports.length > 0) { %>
            <% data.abuseReports.forEach(function(r) { %>
                <div class="report-item">
                    <strong><%= new Date(r.date).toLocaleDateString() %>:</strong> <%= r.comment %>
                </div>
            <% }); %>
        <% } else { %>
            <p style="font-size: 12px; color: #7f8c8d;">Nessuna segnalazione recente rilevata nel database globale.</p>
        <% } %>
    </div>

    <div class="section-title">Raw Whois Data</div>
    <div class="whois-raw"><%= data.whois %></div>

    <div class="footer">ThreatIntel Platform - Intelligence Briefing Document</div>
</body>
</html>
