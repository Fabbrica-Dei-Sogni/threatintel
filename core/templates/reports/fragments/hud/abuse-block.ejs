<div class="hud-item abuse-hud-box" style="border-left-color: var(--text-red);">
    <div class="hud-box-header">
        <span class="hud-box-title"><%= t('reports.fragments.hud.reputationAnalysisTitle') %></span>
        <span class="hud-box-subtitle"><%= t('reports.fragments.confidenceScore').toUpperCase() %></span>
    </div>
    <div class="hud-grid-4">
        <div class="hud-metric danger-<%= Math.floor((data.confidenceScore || data.score || 0) / 20) %>">
            <span class="hud-metric-label"><%= t('reports.fragments.confidenceScore').toUpperCase() %></span>
            <span class="hud-metric-value"><%= data.confidenceScore || data.score || 0 %>%</span>
        </div>
        <div class="hud-metric">
            <span class="hud-metric-label"><%= t('reports.fragments.totalReports').toUpperCase() %></span>
            <span class="hud-metric-value"><%= data.totalReports || data.total || 0 %></span>
        </div>
        <div class="hud-metric">
            <span class="hud-metric-label"><%= t('reports.fragments.isWhitelisted').toUpperCase() %></span>
            <span class="hud-metric-value <%= data.isListed || data.listed === t('common.yes') ? 'text-red' : '' %>">
                <%= (data.isListed || data.listed) ? ( (data.isListed === true || data.listed === t('common.yes')) ? t('common.yes') : t('common.no') ) : t('common.no') %>
            </span>
        </div>
        <div class="hud-metric">
            <span class="hud-metric-label"><%= t('reports.fragments.lastReportedAt').toUpperCase() %></span>
            <span class="hud-metric-value" style="font-size: 10px;"><%= data.lastReportedAt || data.lastReport || 'N/A' %></span>
        </div>
    </div>
    <% if (data.domain || data.isp) { %>
    <div class="hud-footer-details">
        <% if (data.domain) { %><strong><%= t('reports.fragments.domain').toUpperCase() %>:</strong> <%= data.domain %> <% } %>
        <% if (data.isp) { %><strong><%= t('reports.fragments.isp').toUpperCase() %>:</strong> <%= data.isp %><% } %>
    </div>
    <% } %>
</div>
