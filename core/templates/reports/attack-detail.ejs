<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="UTF-8">
    <style>
        body { font-family: 'Helvetica', sans-serif; color: #333; margin: 40px; }
        .header { border-bottom: 2px solid #2c3e50; padding-bottom: 10px; display: flex; justify-content: space-between; }
        .title { color: #2c3e50; text-transform: uppercase; font-size: 20px; }
        .meta { font-size: 12px; margin-top: 20px; background: #f9f9f9; padding: 10px; border-left: 5px solid #2c3e50; }
        .section-title { background: #2c3e50; color: #fff; padding: 5px 10px; margin-top: 30px; font-size: 16px; }
        .grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-top: 10px; }
        .item { font-size: 13px; border-bottom: 1px solid #eee; padding: 5px 0; }
        .label { font-weight: bold; color: #7f8c8d; }
        table { width: 100%; border-collapse: collapse; margin-top: 15px; font-size: 11px; }
        th { background: #ecf0f1; text-align: left; padding: 8px; }
        td { border-bottom: 1px solid #eee; padding: 8px; word-break: break-all; font-family: monospace; }
        .badge { padding: 2px 5px; border-radius: 3px; font-weight: bold; }
        .high { background: #e74c3c; color: #fff; }
        .footer { margin-top: 40px; font-size: 10px; color: #bdc3c7; text-align: center; }
    </style>
</head>
<body>
    <div class="header">
        <div class="title"><%= data.title %></div>
        <div style="color: #e74c3c; font-weight: bold;">SECRET // ANALYST ONLY</div>
    </div>

    <div class="meta">
        <strong>IP Sorgente:</strong> <%= data.ip %><br>
        <strong>Generato il:</strong> <%= data.generatedAt %><br>
        <strong>Sintesi:</strong> <%= data.summary.totalLogs %> log rilevati in <%= data.summary.duration %>
    </div>

    <div class="section-title">IP Intelligence Summary</div>
    <div class="grid">
        <div class="item"><span class="label">Paese:</span> <%= data.ipInfo.country %> (<%= data.ipInfo.countryCode %>)</div>
        <div class="item"><span class="label">ISP:</span> <%= data.ipInfo.isp %></div>
        <div class="item"><span class="label">Abuse Score:</span> <%= data.ipInfo.abuseScore %>%</div>
        <div class="item"><span class="label">Tor:</span> <%= data.ipInfo.isTor ? 'SÌ' : 'NO' %></div>
    </div>

    <div class="section-title">Timeline degli Eventi (Ultimi 100)</div>
    <table>
        <thead>
            <tr>
                <th width="15%">Data/Ora</th>
                <th width="10%">Metodo</th>
                <th>Path / URL</th>
                <th width="10%">Status</th>
            </tr>
        </thead>
        <tbody>
            <% data.events.forEach(function(e) { %>
                <tr>
                    <td><%= new Date(e.timestamp).toLocaleString() %></td>
                    <td><strong><%= e.method %></strong></td>
                    <td><%= e.url %></td>
                    <td><%= e.statusCode %></td>
                </tr>
            <% }); %>
        </tbody>
    </table>

    <div class="footer">ThreatIntel Intelligence Platform - Report Esecutivo</div>
</body>
</html>
