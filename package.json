{
    "name": "threat-intelligence-logger",
    "version": "1.0.0",
    "description": "Sistema di logging per threat intelligence domestica",
    "main": "server.js",
    "scripts": {
        "start": "ts-node server.ts",
        "dev": "nodemon --watch '**/*.ts' --exec 'node --inspect --require ts-node/register' server.ts",
        "build": "tsc",
        "setup": "npm install && npm run setup-nginx",
        "test": "jest core/",
        "test:watch": "jest --watch core/",
        "test:coverage": "jest --coverage core/",
        "test:ci": "jest --ci --coverage --maxWorkers=2 core/",
        "test-ratelimit": "node test/rateLimitTest.js",
        "redis-status": "redis-cli ping",
        "clear-redis": "redis-cli flushdb"
    },
    "dependencies": {
        "@qdrant/js-client-rest": "^1.17.0",
        "axios": ">=1.15.0",
        "cors": "^2.8.5",
        "dotenv": "^17.2.1",
        "ejs": "^5.0.1",
        "express": "^4.18.2",
        "express-rate-limit": "^8.0.1",
        "express-slow-down": "^3.0.0",
        "geoip-lite": "^1.4.7",
        "helmet": "^7.2.0",
        "ioredis": "^5.7.0",
        "ip-range-check": "^0.2.0",
        "ipinfo": "^1.5.2",
        "mongoose": "^7.5.0",
        "puppeteer": "^24.40.0",
        "rate-limit-redis": "^4.2.2",
        "reflect-metadata": "^0.2.2",
        "socket.io": "^4.8.3",
        "swagger-jsdoc": "^6.2.8",
        "swagger-ui-express": "^5.0.1",
        "tsyringe": "^4.10.0",
        "whois": "^2.15.0",
        "winston": "^3.17.0"
    },
    "devDependencies": {
        "@babel/plugin-proposal-class-properties": "^7.18.6",
        "@babel/plugin-proposal-decorators": "^7.28.0",
        "@babel/preset-env": "^7.28.5",
        "@babel/preset-typescript": "^7.28.5",
        "@types/ejs": "^3.1.5",
        "@types/express": "^5.0.5",
        "@types/geoip-lite": "^1.4.4",
        "@types/jest": "^29.5.14",
        "@types/mongoose": "^5.11.96",
        "@types/node": "^24.12.3",
        "@types/socket.io": "^3.0.1",
        "@types/swagger-jsdoc": "^6.0.4",
        "@types/swagger-ui-express": "^4.1.8",
        "ioredis-mock": "^8.9.0",
        "jest": "^29.7.0",
        "mongodb-memory-server": "^9.1.4",
        "nodemon": "^3.0.1",
        "supertest": "^6.3.3",
        "ts-jest": "^29.4.5",
        "ts-node": "^10.9.2",
        "typescript": "^5.9.3"
    }
}
