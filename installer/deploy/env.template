# === THREAT INTEL PRODUCTION CONFIGURATION ===

# --- Logging & Debug ---
LOG_LEVEL=info

# --- Pruning & Cache ---
PRUNING_ENABLED=false
IP_CACHE_MAX_AGE_HOURS=24
ANALYZE_INTERVAL=5m
EXCLUDED_IPS=127.0.0.1,::1

# --- App Settings ---
PORT={{PORT}}
APP_DOMAIN={{APP_DOMAIN}}
API_BASE_URL={{API_BASE_URL}}
ALLOWED_ORIGINS={{ALLOWED_ORIGINS}}
VERSION={{VERSION}}
APP_ID={{APP_ID}}
ABUSEIPDB_KEY={{ABUSEIPDB_KEY}}
COMPOSE_PROJECT_NAME={{SERVICE_NAME}}

# --- Infrastructure Storage ---
STORAGE_ROOT={{STORAGE_ROOT}}

# --- Security & Traps ---
# Endpoint tracciati come trappole (404/418)
COMMON_ENDPOINTS=/admin,/wp-admin,/phpmyadmin,/manager/html,/console,/panel,/control,/dashboard,/api,/api/v1,/rest,/graphql,/uaa,/actuator,/solr,/jenkins,/login,/manage,/setup

# Rate Limiting & Anti-Brute Force
TRAP_WINDOW_MS=300000
TRAP_MAX_REQUESTS=50
APP_WINDOW_MS=60000
APP_MAX_REQUESTS=200

# Blacklist & Violation Logic
MAX_VIOLATIONS=5
BLACKLIST_DURATION=7200
LOG_RATE_LIMIT_EVENTS=true
HONEYPOT_INSTANCE_ID=honeypot-host-001

# --- Dashboard Protection Exemption ---
HONEYPOT_DASHBOARD_PATH={{HONEYPOT_DASHBOARD_PATH}}

# --- MongoDB Configuration ---
MONGO_ROOT_USER={{MONGO_ROOT_USER}}
MONGO_ROOT_PWD={{MONGO_ROOT_PWD}}
MONGO_APP_USER={{MONGO_APP_USER}}
MONGO_APP_PWD={{MONGO_APP_PWD}}
MONGO_APP_DB={{MONGO_APP_DB}}
MONGO_PORT={{MONGO_PORT}}
MONGO_URI=mongodb://{{MONGO_APP_USER}}:{{MONGO_APP_PWD}}@127.0.0.1:{{MONGO_PORT}}/{{MONGO_APP_DB}}

# --- Redis Configuration ---
REDIS_HOST=127.0.0.1
REDIS_PORT={{REDIS_PORT}}
REDIS_PASSWORD={{REDIS_PASSWORD}}
REDIS_DB=0

# --- Qdrant Configuration ---
QDRANT_PORT={{QDRANT_PORT}}
QDRANT_URL=http://127.0.0.1:{{QDRANT_PORT}}
RAG_COLLECTION_NAME={{RAG_COLLECTION_NAME}}
RAG_LOGS_COLLECTION_NAME={{RAG_LOGS_COLLECTION_NAME}}

# --- RAG & AI ---
RAG_ENABLED={{RAG_ENABLED}}
OLLAMA_URL={{OLLAMA_URL}}
EMBEDDING_MODEL={{EMBEDDING_MODEL}}
SUMMARY_MODEL={{SUMMARY_MODEL}}

# AI Advanced Settings
OLLAMA_EMBEDDING_TIMEOUT=30000
OLLAMA_GENERATE_TIMEOUT=60000
OLLAMA_NUM_PREDICT=50
OLLAMA_TEMPERATURE=0.4

# --- Auth ---
URI_DIGITAL_AUTH={{URI_DIGITAL_AUTH}}
ALLOW_ANONYMOUS={{ALLOW_ANONYMOUS}}

# --- Logging ---
NGINX_LOG_PREFIX=nginx_threat_{{SERVICE_NAME}}:
