<div class="classic-item attack-card-formal">
    <div class="formal-header-bar">
        <span class="formal-title"><%= t('reports.fragments.classic.attackSummaryTitle') %></span>
        <span class="formal-id"><%= t('reports.fragments.classic.refId') %>: <%= Math.random().toString(36).substring(7).toUpperCase() %></span>
    </div>
    <table class="formal-data-grid">
        <tr>
            <th width="30%"><%= t('reports.fragments.classic.subjectIndividual') %></th>
            <td><strong><%= data.ip %></strong></td>
        </tr>
        <tr>
            <th><%= t('reports.fragments.classic.dangerScore') %></th>
            <td><span class="classic-danger-val"><%= (data.score || 0).toFixed(2) %> / 10.00</span></td>
        </tr>
        <tr>
            <th><%= t('reports.fragments.classic.volumeLogs') %></th>
            <td><%= t('reports.fragments.classic.eventsDetected', { count: data.totalLogs }) %></td>
        </tr>
        <tr>
            <th><%= t('reports.fragments.classic.techniquesIdentified') %></th>
            <td><%= data.techniques || t('reports.fragments.classic.noneSpecified') %></td>
        </tr>
        <tr>
            <th><%= t('reports.fragments.classic.timeWindow') %></th>
            <td><%= data.firstSeen %> — <%= data.lastSeen %></td>
        </tr>
    </table>
</div>
