PORT={{PORT}}
APP_DOMAIN={{APP_DOMAIN}}
ALLOWED_ORIGINS={{ALLOWED_ORIGINS}}
VERSION={{VERSION}}
APP_ID={{APP_ID}}

# --- Infrastructure Storage ---
STORAGE_ROOT={{STORAGE_ROOT}}

# --- MongoDB Configuration ---
MONGO_ROOT_USER={{MONGO_ROOT_USER}}
