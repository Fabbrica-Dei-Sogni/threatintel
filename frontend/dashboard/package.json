{
    "name": "honeypot-dashboard",
    "version": "0.1.2",
    "publishConfig": {
        "registry": "http://alessandromodica.com:8081/repository/npm-cloud-pubblico/"
    },
    "scripts": {
        "dev": "vite --config vite.config.ts --host",
        "build": "vue-tsc -p tsconfig.app.json --noEmit && vite build --config vite.config.ts",
        "build:full": "vue-tsc --noEmit && vite build --config vite.config.ts",
        "preview": "vite preview",
        "type-check": "vue-tsc -p tsconfig.app.json --noEmit",
        "type-check:all": "vue-tsc --noEmit",
        "test": "vitest",
        "test:coverage": "vitest run --coverage",
        "release": "npm version $npm_config_versione -m 'Rilasciata una nuova release frontend' && git push",
        "patch": "npm version patch -m 'Rilasciata una nuova patch frontend' && git push"
    },
    "dependencies": {
        "axios": ">=1.15.0",
        "chart.js": "^4.4.0",
        "chartjs-adapter-dayjs-4": "^1.0.4",
        "dayjs": "^1.11.9",
        "element-plus": "^2.11.2",
        "leaflet": "^1.9.4",
        "pinia": "^2.1.4",
        "socket.io-client": "^4.8.3",
        "vue": "^3.3.4",
        "vue-chartjs": "^5.1.1",
        "vue-i18n": "^10.0.8",
        "vue-router": "^4.3.4"
    },
    "devDependencies": {
        "@types/leaflet": "^1.9.21",
        "@types/node": "^24.5.2",
        "@types/socket.io-client": "^1.4.36",
        "@vitejs/plugin-vue": "^6.0.1",
        "@vitest/coverage-v8": "^4.1.5",
        "@vue/test-utils": "^2.4.6",
        "@vue/tsconfig": "^0.8.1",
        "axios-mock-adapter": "^2.1.0",
        "happy-dom": "^20.9.0",
        "typescript": "^5.9.2",
        "vite": ">=7.3.2",
        "vite-plugin-pwa": "^1.2.0",
        "vitest": "^4.1.5",
        "vue-tsc": "^3.0.7"
    },
    "overrides": {
        "serialize-javascript": "^7.0.5"
    }
}
