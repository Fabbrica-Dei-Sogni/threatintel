<div class="hud-item human-note-box">
    <div class="hud-box-header">
        <span class="hud-box-title" style="color: #f59e0b;">
            > <%= t('reports.common.analystNote').toUpperCase() %>
        </span>
        <span class="hud-box-type" style="border-color: #f59e0b; color: #f59e0b;">[HUMAN_RECORD]</span>
    </div>
    <div class="hud-generic-content" style="border-left: 2px solid #f59e0b; background: rgba(245, 158, 11, 0.05); padding: 15px;">
        <pre class="hud-mono-text" style="color: #fde68a;"><%= data.text %></pre>
    </div>
</div>
