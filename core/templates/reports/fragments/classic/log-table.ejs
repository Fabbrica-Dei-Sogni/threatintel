<div class="classic-item forensic-log-block">
    <div class="log-grid-header">
        <span class="log-method-rect <%= data.method %>"><%= data.method %></span>
        <span class="log-url-rect"><%= data.url %></span>
        <span class="log-score-rect"><%= t('reports.fragments.classic.score') %>: <%= data.score %></span>
    </div>
    <div class="log-grid-body">
        <div class="log-row">
            <strong><%= t('reports.fragments.classic.timestamp') %>:</strong> <%= data.timestamp %>
        </div>
        <div class="log-row">
            <strong><%= t('reports.fragments.classic.indicators') %>:</strong> <span class="indicator-text"><%= data.indicators %></span>
        </div>
        <% if (data.userAgent) { %>
            <div class="log-row">
                <strong><%= t('reports.fragments.classic.userAgent') %>:</strong> <%= data.userAgent %>
            </div>
        <% } %>
        <div class="log-payload-area">
            <strong><%= t('reports.fragments.classic.extractedPayload') %>:</strong>
            <pre class="payload-box-classic"><%= data.payload %></pre>
        </div>
    </div>
</div>
