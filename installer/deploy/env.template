# === THREAT INTEL PRODUCTION CONFIGURATION ===

# --- App Settings ---
PORT={{PORT}}
APP_DOMAIN={{APP_DOMAIN}}
API_BASE_URL={{API_BASE_URL}}
ALLOWED_ORIGINS={{ALLOWED_ORIGINS}}
VERSION={{VERSION}}
APP_ID={{APP_ID}}
COMPOSE_PROJECT_NAME={{SERVICE_NAME}}

# --- Infrastructure Storage ---
STORAGE_ROOT={{STORAGE_ROOT}}

# --- MongoDB Configuration ---
MONGO_ROOT_USER={{MONGO_ROOT_USER}}
MONGO_ROOT_PWD={{MONGO_ROOT_PWD}}
MONGO_APP_USER={{MONGO_APP_USER}}
MONGO_APP_PWD={{MONGO_APP_PWD}}
MONGO_APP_DB={{MONGO_APP_DB}}
MONGO_PORT={{MONGO_PORT}}
MONGO_URI=mongodb://{{MONGO_APP_USER}}:{{MONGO_APP_PWD}}@127.0.0.1:{{MONGO_PORT}}/{{MONGO_APP_DB}}

# --- Redis Configuration ---
REDIS_HOST=127.0.0.1
REDIS_PORT={{REDIS_PORT}}
REDIS_PASSWORD={{REDIS_PASSWORD}}
REDIS_DB=0

# --- Qdrant Configuration ---
QDRANT_PORT={{QDRANT_PORT}}
QDRANT_URL=http://127.0.0.1:{{QDRANT_PORT}}
RAG_COLLECTION_NAME={{RAG_COLLECTION_NAME}}
RAG_LOGS_COLLECTION_NAME={{RAG_LOGS_COLLECTION_NAME}}

# --- RAG & AI (Managed via App/Backoffice in the future) ---
RAG_ENABLED={{RAG_ENABLED}}
OLLAMA_URL={{OLLAMA_URL}}
EMBEDDING_MODEL={{EMBEDDING_MODEL}}
SUMMARY_MODEL={{SUMMARY_MODEL}}

# --- Auth ---
URI_DIGITAL_AUTH={{URI_DIGITAL_AUTH}}
ALLOW_ANONYMOUS={{ALLOW_ANONYMOUS}}

# --- Logging ---
NGINX_LOG_PREFIX=nginx_threat_{{SERVICE_NAME}}:
