<div class="classic-item classic-human-note" style="margin-top: 15px; page-break-inside: avoid;">
    <div class="note-line-header" style="border-bottom: 1px solid #cbd5e1; margin-bottom: 10px; padding-bottom: 4px;">
        <span style="font-size: 8px; font-weight: 800; color: #64748b; text-transform: uppercase; letter-spacing: 1px;">
            <%= t('reports.common.analystNote') %>
        </span>
    </div>
    <div class="note-line-body">
        <p style="font-size: 10px; line-height: 1.5; color: #334155; white-space: pre-wrap; font-style: italic; margin: 0;">
            <%= data.text %>
        </p>
    </div>
</div>
