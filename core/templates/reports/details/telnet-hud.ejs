<!DOCTYPE html>
<html lang="<%= locale.split('-')[0] %>">
<head>
    <meta charset="UTF-8">
    <title><%= t('reports.common.agencyName') %> - <%= t('reports.common.telnetSshInvestigative').toUpperCase() %> - <%= data.sessionId %></title>
    <style>
        :root {
            --hud-bg: #0a0b0d;
            --hud-surface: #15191c;
            --hud-border: #232a2f;
            --hud-accent: #00d4ff;
            --hud-text-main: #e0e6ed;
            --hud-text-dim: #94a3b8;
            --hud-danger: #f43f5e;
            --hud-warning: #fbbf24;
            --hud-success: #10b981;
            --hud-font: 'JetBrains Mono', 'Segoe UI Mono', monospace;
        }

        @page {
            margin: 10mm;
            size: A4;
        }

        body {
            font-family: var(--hud-font);
            background-color: var(--hud-bg);
            color: var(--hud-text-main);
            margin: 0;
            padding: 0;
            line-height: 1.2;
            font-size: 11px;
        }

        .hud-container { padding: 20px; }

        .hud-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 2px solid var(--hud-accent);
            padding-bottom: 15px;
            margin-bottom: 25px;
        }

        .hud-header-left { display: flex; align-items: center; gap: 15px; }

        .hud-logo {
            width: 45px; height: 45px;
            border: 1px solid var(--hud-accent);
            padding: 5px; background: rgba(0, 212, 255, 0.05);
        }

        .hud-logo img {
            width: 100%; height: 100%; object-fit: contain;
            filter: brightness(0) invert(1) drop-shadow(0 0 2px var(--hud-accent));
        }

        .hud-title h1 {
            margin: 0; font-size: 20px; text-transform: uppercase;
            letter-spacing: 2px; color: var(--hud-accent);
            text-shadow: 0 0 8px rgba(0, 212, 255, 0.3);
        }

        .hud-title p { margin: 2px 0 0; font-size: 9px; color: var(--hud-text-dim); text-transform: uppercase; }

        .hud-header-right { text-align: right; }

        .hud-stamp {
            border: 1px solid var(--hud-warning); color: var(--hud-warning);
            padding: 4px 10px; font-size: 10px; font-weight: bold;
            text-transform: uppercase; background: rgba(251, 191, 36, 0.1);
        }

        .hud-grid {
            display: grid; grid-template-columns: repeat(2, 1fr);
            gap: 15px; margin-bottom: 20px;
        }

        .hud-block {
            background: var(--hud-surface); border: 1px solid var(--hud-border);
            padding: 12px; position: relative;
        }

        .hud-block::before {
            content: ""; position: absolute; top: -1px; left: -1px;
            width: 10px; height: 10px; border-top: 2px solid var(--hud-accent);
            border-left: 2px solid var(--hud-accent);
        }

        .hud-block-title {
            font-size: 10px; color: var(--hud-accent);
            text-transform: uppercase; margin-bottom: 10px;
            display: flex; justify-content: space-between;
        }

        .hud-value-row {
            display: flex; justify-content: space-between;
            margin-bottom: 6px; border-bottom: 1px dashed var(--hud-border);
            padding-bottom: 4px;
        }

        .hud-label { color: var(--hud-text-dim); }
        .hud-value { font-weight: bold; color: var(--hud-text-main); }

        .hud-stats-grid {
            display: grid; grid-template-columns: repeat(4, 1fr);
            gap: 10px; margin-top: 10px;
        }

        .hud-stat-box {
            background: rgba(0, 212, 255, 0.05); border: 1px solid var(--hud-border);
            padding: 8px; text-align: center;
        }

        .hud-stat-value { font-size: 14px; font-weight: bold; color: var(--hud-accent); display: block; }
        .hud-stat-label { font-size: 8px; color: var(--hud-text-dim); text-transform: uppercase; }

        .timeline-container { margin-top: 10px; }

        .timeline-entry {
            display: flex; gap: 15px; margin-bottom: 10px;
            padding-left: 10px; border-left: 1px solid var(--hud-accent);
            position: relative;
        }

        .timeline-entry::before {
            content: ""; position: absolute; left: -4px; top: 0;
            width: 7px; height: 7px; background: var(--hud-accent);
            box-shadow: 0 0 5px var(--hud-accent);
        }

        .timeline-time { min-width: 60px; color: var(--hud-accent); font-size: 9px; }
        .timeline-content { flex-grow: 1; }
        .timeline-type {
            font-weight: bold; text-transform: uppercase; font-size: 9px;
            display: block; margin-bottom: 2px;
        }

        .type-login { color: var(--hud-warning); }
        .type-command { color: var(--hud-success); }
        .type-other { color: var(--hud-text-dim); }

        .timeline-message {
            background: rgba(0, 0, 0, 0.2); padding: 4px 8px;
            border-left: 2px solid var(--hud-border); color: var(--hud-text-main);
            font-size: 10px; word-break: break-all;
        }

        .command-input { color: var(--hud-accent); font-weight: bold; }
    </style>
</head>
<body>
    <div class="hud-container">
        <header class="hud-header">
            <div class="hud-header-left">
                <div class="hud-logo">
                    <img src="<%= logoBase64 %>" alt="Agency Logo">
                </div>
                <div class="hud-title">
                    <h1><%= t('reports.fragments.telnetSummaryTitle').toUpperCase() %></h1>
                    <p><%= t('reports.common.agencyName') %> // <%= t('reports.common.analysis').toUpperCase() %></p>
                </div>
            </div>
            <div class="hud-header-right">
                <div class="hud-stamp"><%= t('reports.common.confidential').toUpperCase() %> // <%= t('reports.common.internalUseOnly').toUpperCase() %></div>
                <p style="font-size: 8px; color: var(--hud-text-dim); margin-top: 5px;"><%= t('reports.fragments.hud.timestamp').toUpperCase() %>: <%= data.generatedAt %></p>
            </div>
        </header>

        <div class="hud-grid">
            <!-- SESSION INTEL -->
            <div class="hud-block">
                <div class="hud-block-title">
                    <span><%= t('reports.telnetDetail.overview').toUpperCase() %></span>
                    <span>[SYS.SESSION]</span>
                </div>
                <div class="hud-value-row">
                    <span class="hud-label"><%= t('reports.common.id').toUpperCase() %>:</span>
                    <span class="hud-value" style="color: var(--hud-accent);"><%= data.sessionId %></span>
                </div>
                <div class="hud-value-row">
                    <span class="hud-label"><%= t('reports.fragments.hud.ip').toUpperCase() %>:</span>
                    <span class="hud-value"><%= data.ip %></span>
                </div>
                <div class="hud-value-row">
                    <span class="hud-label"><%= t('reports.fragments.startTime').toUpperCase() %>:</span>
                    <span class="hud-value"><%= data.sessionInfo.startTime %></span>
                </div>
                <div class="hud-value-row">
                    <span class="hud-label"><%= t('reports.common.protocol').toUpperCase() %>:</span>
                    <span class="hud-value"><%= data.sessionInfo.protocol %></span>
                </div>
                <div class="hud-stats-grid">
                    <div class="hud-stat-box">
                        <span class="hud-stat-value"><%= data.sessionInfo.totalEvents %></span>
                        <span class="hud-stat-label"><%= t('reports.fragments.hud.logs').toUpperCase() %></span>
                    </div>
                    <div class="hud-stat-box">
                        <span class="hud-stat-value"><%= data.sessionInfo.authAttempts %></span>
                        <span class="hud-stat-label"><%= t('reports.telnetDetail.authAttempts').toUpperCase() %></span>
                    </div>
                    <div class="hud-stat-box">
                        <span class="hud-stat-value"><%= data.sessionInfo.commands %></span>
                        <span class="hud-stat-label"><%= t('reports.telnetDetail.commands').toUpperCase() %></span>
                    </div>
                    <div class="hud-stat-box">
                        <span class="hud-stat-value"><%= data.sessionInfo.duration %></span>
                        <span class="hud-stat-label"><%= t('reports.telnetDetail.duration').toUpperCase() %></span>
                    </div>
                </div>
            </div>

            <!-- GEO-INTEL -->
            <div class="hud-block">
                <div class="hud-block-title">
                    <span><%= t('reports.fragments.hud.geolocDataTitle').toUpperCase() %></span>
                    <span>[SYS.GEO]</span>
                </div>
                <div class="hud-value-row">
                    <span class="hud-label"><%= t('reports.fragments.country').toUpperCase() %>:</span>
                    <span class="hud-value"><%= data.ipInfo.country %> (<%= data.ipInfo.countryCode %>)</span>
                </div>
                <div class="hud-value-row">
                    <span class="hud-label"><%= t('reports.fragments.city').toUpperCase() %>:</span>
                    <span class="hud-value"><%= data.ipInfo.city %></span>
                </div>
                <div class="hud-value-row">
                    <span class="hud-label"><%= t('reports.fragments.coordinates').toUpperCase() %>:</span>
                    <span class="hud-value"><%= data.ipInfo.coordinates %></span>
                </div>
                <div class="hud-value-row">
                    <span class="hud-label"><%= t('reports.fragments.isp').toUpperCase() %>:</span>
                    <span class="hud-value"><%= data.ipInfo.isp %></span>
                </div>
                <div class="hud-value-row" style="margin-top: 10px;">
                    <span class="hud-label"><%= t('reports.fragments.confidenceScore').toUpperCase() %>:</span>
                    <span class="hud-value <%= data.abuse.confidenceScore > 50 ? 'hud-danger' : 'hud-success' %>"><%= data.abuse.confidenceScore %>%</span>
                </div>
            </div>
        </div>

        <!-- TIMELINE -->
        <div class="hud-block">
            <div class="hud-block-title">
                <span><%= t('reports.telnetDetail.timeline').toUpperCase() %></span>
                <span>[RAW_STREAM]</span>
            </div>
            <div class="timeline-container">
                <% data.timeline.forEach(event => { %>
                    <div class="timeline-entry">
                        <div class="timeline-time"><%= new Date(event.timestamp).toLocaleTimeString(locale) %></div>
                        <div class="timeline-content">
                            <% if (event.type.includes('login')) { %>
                                <span class="timeline-type type-login"><%= t('reports.common.authAttempt').toUpperCase() %></span>
                                <div class="timeline-message">
                                    <%= t('reports.fragments.hud.usr').toUpperCase() %>: <span style="color: var(--hud-accent);"><%= event.username || '?' %></span> 
                                    <%= t('reports.fragments.hud.pwd').toUpperCase() %>: <span style="color: var(--hud-warning);"><%= event.password || '?' %></span>
                                </div>
                            <% } else if (event.input) { %>
                                <span class="timeline-type type-command"><%= t('reports.common.command').toUpperCase() %></span>
                                <div class="timeline-message command-input">$ <%= event.input %></div>
                            <% } else { %>
                                <span class="timeline-type type-other"><%= event.type.replace('cowrie.', '').toUpperCase() %></span>
                                <% if (event.message) { %>
                                    <div class="timeline-message"><%= event.message %></div>
                                <% } %>
                            <% } %>
                        </div>
                    </div>
                <% }); %>
            </div>
        </div>

    </div>
</body>
</html>
